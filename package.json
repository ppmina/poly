{
  "name": "poly",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "check": "pnpm guard:toolchain && turbo run check",
    "dev:web": "pnpm --filter @poly/web dev",
    "guard:toolchain": "node tools/check-shared-toolchain.mjs",
    "lint": "pnpm guard:toolchain && turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt . --check",
    "paper": "pnpm --filter @poly/trader paper",
    "replay": "pnpm --filter @poly/trader replay",
    "research:dataset": "uv run python tools/research/build_dataset.py",
    "research:replay": "uv run python tools/research/replay_session.py",
    "research:signal": "uv run python tools/research/generate_signal.py",
    "research:signal:nn": "uv run python tools/research/generate_nn_signal.py",
    "research:train": "uv run python tools/research/train_signal_model.py",
    "test": "turbo run test"
  },
  "devDependencies": {
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.10"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
