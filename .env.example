ARTIFACTS_DIR=artifacts
KILL_SWITCH_FILE=artifacts/kill-switch.json
ALLOW_LIVE_EXECUTION=false
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_API_KEY=
