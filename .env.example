MAX_NOTIONAL=25
MAX_DRAWDOWN=5
STALE_DATA_MS=15000
INVENTORY_SKEW_BPS=80
PAPER_INITIAL_CASH=1000
PAPER_FILL_SLIPPAGE_BPS=2
SIGNAL_FILE_PATH=artifacts/signals/current.json
